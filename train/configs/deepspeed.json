{
  "fp16": {
    "enabled": "auto"
  },
  "bf16": {
    "enabled": true
  },
  "optimizer": {
    "type": "adamw_torch",
    "params": {
      "lr": 1e-4,
      "weight_decay": 0.01,
      "beta1": 0.9,
      "beta2": 0.999
    }
  },
  "scheduler": {
    "type": "cosine",
    "params": {
      "warmup_ratio": 0.1,
      "cosine_lr_constant_ratio": 0.1
    }
  },
  "zero_optimization": {
    "stage": 2,
    "offload_optimizer": {
      "device": "cpu",
      "pin_memory": true
    },
    "allgather_partitions": true,
    "allgather_bucket_size": 2e8,
    "reduce_scatter": true,
    "reduce_bucket_size": 2e8,
    "overlap_comm": true,
    "contiguous_gradients": true
  },
  "gradient_accumulation_steps": "auto",
  "gradient_clipping": 1.0,
  "steps_per_print": 10,
  "train_batch_size": "auto",
  "train_micro_batch_size_per_gpu": "auto",
  "wall_clock_breakdown": false
}
